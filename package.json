{
  "name": "owen-zen",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "generate:icons": "node scripts/generate-icons.mjs",
    "electron:dev": "npm run electron:compile && concurrently \"next dev -p 3005\" \"wait-on http://localhost:3005 && electron . --dev-port=3005\"",
    "electron:build": "npm run electron:compile && node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build && electron-builder",
    "electron:compile": "node electron/build.js",
    "electron:preview": "electron .",
    "backup": "node scripts/backup-db.ts local",
    "backup:s3": "node scripts/backup-db.ts s3",
    "backup:verify": "node scripts/backup-db.ts verify",
    "backup:list": "node scripts/backup-db.ts list"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "googleapis": "^171.4.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.563.0",
    "mongoose": "^9.1.5",
    "next": "16.1.6",
    "next-cloudinary": "^6.17.5",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.2",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.2.1",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.owenZen.app",
    "productName": "Owen Zen",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/next/**/*",
      "node_modules/@next/**/*",
      "node_modules/idb/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/next/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.png",
      "uninstallerIcon": "public/icon.png",
      "installerHeaderIcon": "public/icon.png"
    }
  }
}
